# Whitelist only the folders we want to track
/*
!/.gitignore
!/Streaker Detect/
!/Get_TLE/
!/Record/
!/Sat_Calcs/
!/Dahua_Display/

# Streaker Detect — exclude build artifacts and generated output
/Streaker Detect/build/
/Streaker Detect/dist/
/Streaker Detect/__pycache__/
/Streaker Detect/*.pyc
/Streaker Detect/synth_test_results/
/Streaker Detect/compare_results/
/Streaker Detect/event_*/
/Streaker Detect/clips_*/
/Streaker Detect/*.log
/Streaker Detect/streaker_config.json

# Get_TLE — exclude credentials, downloaded TLE data, and logs
/Get_TLE/tle_config.json
/Get_TLE/TLEz/
/Get_TLE/*.log

# Record — exclude credentials and build artifacts
/Record/stream_capture_config.json
/Record/build/
/Record/dist/
/Record/python/
/Record/__pycache__/
/Record/*.pyc

# Sat_Calcs — exclude cache
/Sat_Calcs/__pycache__/
/Sat_Calcs/*.pyc

# Dahua_Display — exclude credentials, build artifacts, and logs
/Dahua_Display/dahua_display_config.json
/Dahua_Display/build/
/Dahua_Display/dist/
/Dahua_Display/__pycache__/
/Dahua_Display/*.pyc
/Dahua_Display/*.log
